{
  "name": "stt-desktop",
  "version": "1.0.7",
  "description": "한국어 음성 SOAP 진료 기록 데스크탑 앱",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prebuild": "node scripts/prepare-resources.js",
    "build:win": "node scripts/prepare-resources.js && electron-builder --win --x64 --publish never",
    "build:mac": "node scripts/prepare-resources.js && electron-builder --mac",
    "build:linux": "node scripts/prepare-resources.js && electron-builder --linux"
  },
  "build": {
    "appId": "com.stt.desktop",
    "productName": "ClickCNS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "files": [
      "src/**"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend"
      },
      {
        "from": "resources/frontend",
        "to": "frontend"
      },
      {
        "from": "resources/python",
        "to": "python"
      },
      {
        "from": "resources/model",
        "to": "model"
      },
      {
        "from": "resources/vc_redist.x64.exe",
        "to": "vc_redist.x64.exe"
      }
    ],
    "asar": true
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
